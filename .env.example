# Copy this file to `.env` and fill in the secrets. `.env` is gitignored.

# ---- Anthropic API -----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Graph MCP server (variant=mcp) ------------------------------------------
# Shared connector settings. The *project* that holds a corpus's schemas is not
# set here — it lives in corpora/<name>/corpus.yaml under sources.mcp.project_id.
# URL of the MCP server that exposes the typed schema graph.
MCP_SERVER_URL=https://go.coremodels.io/mcp
# Bearer token — sent to the MCP server as the `Authorization: Bearer <token>` header.
MCP_TOKEN=your-mcp-token
